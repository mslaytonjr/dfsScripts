# =============================================================================
# Required run identity
# =============================================================================
# Default page to test. When LOBS is set, each LOB can override this with
# LOB.TARGET_URL.
TARGET_URL=https://example.com/login

# Release/build label used for the evidence folder and, by default, the expected
# dfs_E_8 value.
RELEASE_VERSION=dfs_E_8

# If dfs_E_8 should equal something different from RELEASE_VERSION, set it here.
# This is compared as one exact literal value, including commas.
EXPECTED_DFS_E_8=


# =============================================================================
# Lines of business
# =============================================================================
# Optional comma-separated LOB list. The runner executes every selected browser
# once per LOB and writes evidence under evidence/<release>/<lob>/<browser>/...
LOBS=

# Any setting can be made LOB-specific with LOB.PROPERTY. Unprefixed values
# remain defaults for settings that are not overridden.
# PUBLIC.TARGET_URL=https://www.example.com/login
# PUBLIC.USERNAME_SELECTOR=#public-user
# PUBLIC.PASSWORD_SELECTOR=#public-password
# PUBLIC.SUBMIT_SELECTOR=#public-submit
# PUBLIC.LOGIN_REQUEST_MATCHER=/login|auth|signin/i
# SECURE.TARGET_URL=https://secure.example.com/login
# SECURE.HEADLESS=false
# SECURE.LOGIN_FRAME_SELECTOR=iframe[name="logonbox"]
# SECURE.LOGIN_FRAME_NAME=logonbox
# SECURE.LOGIN_BEFORE_MOUSE=true
# SECURE.LOGIN_BEFORE_RELOAD=true
# SECURE.USERNAME_SELECTOR=#secure-user
# SECURE.PASSWORD_SELECTOR=#secure-password
# SECURE.SUBMIT_SELECTOR=#secure-submit
# SECURE.LOGIN_REQUEST_MATCHER=/login|auth|signin/i


# =============================================================================
# Browser selection and launch behavior
# =============================================================================
# Optional comma-separated browser keys from browser-paths.properties.
# Leave blank to run every configured executable path.
BROWSERS=

# true runs headless. Keep this enabled for request-capture flows where headed
# automation changes or blocks the requests under test.
HEADLESS=true

# Playwright cannot reliably drive stock Firefox in every environment. Keep true
# to use Playwright's bundled Firefox for firefox targets.
FIREFOX_USE_PLAYWRIGHT_BUNDLED=true


# =============================================================================
# Test scope
# =============================================================================
# Move the mouse during the telemetry test. This is useful for validating DFS
# user-interaction updates.
PERFORM_MOUSE_MOVEMENT=true

# Reload the page and validate dfs_F_1 session stability. By default this runs
# before logon. Set LOB.LOGIN_BEFORE_RELOAD=true when a LOB's login form is only
# reliably available on the first page load.
PERFORM_RELOAD_TEST=true

# Run login validation before the reload/session-stability check.
LOGIN_BEFORE_RELOAD=false

# Run login validation before mouse telemetry. Use this for login pages whose
# iframe/form is visible immediately but later becomes hidden or re-rendered.
LOGIN_BEFORE_MOUSE=false

# Stop after page load and input discovery. Use this to find selectors before
# enabling logon submission.
DISCOVER_INPUTS_ONLY=false

# Enables the login form submission validation. SUBMIT_CREDENTIALS is the legacy
# compatibility flag used only when TEST_LOGON is unset.
TEST_LOGON=false
SUBMIT_CREDENTIALS=false


# =============================================================================
# Script override
# =============================================================================
# Optional: load the prod page but replace requested JS files with test builds.
# *_MATCH can be a substring or regex like /\/dfs-agent\.js(\?|$)/i.
# *_SOURCE can be an HTTPS URL or local JS file path.
SCRIPT_OVERRIDE_MATCH=
SCRIPT_OVERRIDE_SOURCE=
LEVO_SCRIPT_OVERRIDE_MATCH=
LEVO_SCRIPT_OVERRIDE_SOURCE=
SCRIPT_OVERRIDE_FETCH_TIMEOUT_MS=30000


# =============================================================================
# Login form and request capture
# =============================================================================
# Required only when TEST_LOGON=true.
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Selectors used by Playwright to fill and submit the login form.
LOGIN_FRAME_SELECTOR=
LOGIN_FRAME_NAME=
LOGIN_FRAME_URL_MATCHER=
LOGIN_FRAME_WAIT_TIMEOUT_MS=45000
SECURE_SYSTEM_REQUIREMENTS_SIGNIN_RECOVERY=true
SECURE_SIGNIN_LINK_TIMEOUT_MS=10000
USERNAME_SELECTOR=#userId-input-field-input
PASSWORD_SELECTOR=#password-input-field-input
SUBMIT_SELECTOR=#signin-button

# Regex or substring used to identify the login/auth network request after
# submit. Regex values should be wrapped in /.../flags.
LOGIN_REQUEST_MATCHER=/login|auth|signin/i


# =============================================================================
# Human-like input timing
# =============================================================================
# Delay between keystrokes for username/password typing. Per-field settings
# override TYPE_DELAY_MS when populated.
TYPE_DELAY_MS=50
USERNAME_TYPE_DELAY_MS=
PASSWORD_TYPE_DELAY_MS=

# Pause after typing credentials and before pressing submit.
BEFORE_SUBMIT_WAIT_MS=750


# =============================================================================
# Page, cookie, and request timing
# =============================================================================
NAVIGATION_TIMEOUT_MS=30000
POST_LOAD_WAIT_MS=2000
POST_RELOAD_WAIT_MS=5000
FIELD_TIMEOUT_MS=45000
LOGIN_REQUEST_TIMEOUT_MS=30000
POST_SUBMIT_TIMEOUT_MS=30000
POST_SUBMIT_LOAD_STATE=networkidle

# Optional wait before reading cookies. COOKIE_SETTLE_WAIT_MS applies to both
# phases unless INITIAL_COOKIE_WAIT_MS or POST_SUBMIT_COOKIE_WAIT_MS is set.
COOKIE_SETTLE_WAIT_MS=0
INITIAL_COOKIE_WAIT_MS=
POST_SUBMIT_COOKIE_WAIT_MS=
# Isolated control tests wait for FingerprintData and dfs_E_7 before deciding
# DFS is unavailable. If the page redirects to Chase system requirements the
# control is skipped; otherwise missing DFS data is a failure.
FINGERPRINT_DATA_WAIT_TIMEOUT_MS=15000
DFS_E7_WAIT_TIMEOUT_MS=15000

# Mouse telemetry timing.
MOUSE_WAIT_BEFORE_MS=15000
MOUSE_WAIT_AFTER_MS=1000

# Numeric dfs_E_7 agentic scoring. dfs_E_7 is expected to be a variable-length
# string of 2-digit score tokens. The runner de-permutes tokens from dfs_F_5.
DFS_E7_FORMAT=auto
DFS_E7_SCORE_SHUFFLE_MAPPING=canonical-index-to-shuffled-index

# User interaction scenario tests. These run each scenario in a fresh browser
# context so behavior score tokens do not leak between scenarios.
# INTERACTION_TEST_SCENARIOS accepts either aliases A1-C4 or long names.
#
# Alias -> long name -> assertion:
#   A1 -> value_injection      -> token[0] valueInjection ~= min(99, round(100 * injectedFields / totalFields))
#   A2 -> synthetic_events     -> token[1] syntheticEvents >= 80
#   A3 -> pointer_lock         -> token[2] pointerLock >= 60
#   A4 -> pointer_travel       -> token[3] pointerTravel >= 50
#   A5 -> cold_focus           -> token[4] coldFocus >= 80
#   B1 -> injected_text        -> token[5] field1.injectedText >= 90
#   B2 -> cadence_rigidity     -> token[7] field1.cadenceRigidity >= 80
#   B3 -> human_like_cadence   -> token[7] field1.cadenceRigidity <= 30
#   B4 -> focus_anomaly        -> token[8] field1.focusAnomaly >= 90
#   B5 -> dwell_missing_keyups -> token[9] field1.dwellAnomaly >= 90
#   B6 -> dwell_short_holds    -> token[9] field1.dwellAnomaly >= 80
#   B7 -> fill_speed           -> token[10] field1.fillSpeed >= 85
#   B8 -> paste_fragmentation  -> token[6] field1.pasteFragmentation >= 90
#   B9 -> focus_no_pointer     -> token[11] field1.focusNoPointer = 99
#   B10 -> key_input_mismatch_cdp -> token[12] field1.keyInputMismatch >= 90; Chromium only
#   B11 -> key_input_mismatch_paste_negative -> token[12] field1.keyInputMismatch = 0
#   C1 -> human_baseline       -> all tokens <= 0
#   C2 -> human_pause_baseline -> all tokens <= 20
#   C3 -> human_mouse_path     -> token[3] pointerTravel <= 20
#   C4 -> browser_autofill_suppression -> autofill-suppressed field/global tokens = 0 when autofill is observed
PERFORM_INTERACTION_SCENARIO_TESTS=true
INTERACTION_TEST_SCENARIOS=A1,A2,A3,A4,A5,B1,B2,B3,B4,B5,B6,B7,B8,B9,B10,B11,C1,C2,C3,C4
INTERACTION_TEST_VALUE=testuser1
ROBOTIC_TYPING_DELAY_MS=50
CADENCE_RIGIDITY_USE_MANUAL_EVENTS=true
CADENCE_RIGIDITY_FORCE_SYNTHETIC_SUBMIT=true
HUMAN_TYPE_MIN_DELAY_MS=50
HUMAN_TYPE_MAX_DELAY_MS=300
HUMAN_LIKE_CADENCE_HIGH_VARIANCE=true
HUMAN_LIKE_CADENCE_FORCE_SYNTHETIC_SUBMIT=true
HUMAN_BASELINE_TYPE_MIN_DELAY_MS=50
HUMAN_BASELINE_TYPE_MAX_DELAY_MS=300
HUMAN_PAUSE_MS=500
HUMAN_MOUSE_STEPS=24
HUMAN_BASELINE_CLICK_REAL_SUBMIT=false
FOCUS_ANOMALY_FORCE_SYNTHETIC_SUBMIT=true
FOCUS_ANOMALY_USE_SCRATCH_FIELD=false
DWELL_ANOMALY_FORCE_SYNTHETIC_SUBMIT=true
FILL_SPEED_SELECTOR=
FILL_SPEED_TEXT=
FILL_SPEED_FORCE_SYNTHETIC_SUBMIT=true
POINTER_LOCK_CLICK_COUNT=5
POINTER_LOCK_USE_SCRATCH_TARGETS=true
POINTER_LOCK_USE_LOCATOR_CLICK=false
POINTER_LOCK_FORCE_SYNTHETIC_SUBMIT=true
POINTER_TRAVEL_CLICK_COUNT=3
POINTER_TRAVEL_USE_MOUSE_TELEPORT=true
POINTER_TRAVEL_FORCE_SYNTHETIC_SUBMIT=true
COLD_FOCUS_TYPE_DELAY_MS=60
FOCUS_NO_POINTER_TYPE_DELAY_MS=60
VALUE_INJECTION_FIELD_COUNT=4
VALUE_INJECTION_ECHO_WINDOW_WAIT_MS=2000
VALUE_INJECTION_DISPATCH_EVENTS=true
VALUE_INJECTION_USE_NATIVE_SETTER=false
VALUE_INJECTION_FORCE_SYNTHETIC_SUBMIT=true
SYNTHETIC_EVENTS_FIELD_COUNT=4
INJECTED_TEXT_ECHO_WINDOW_WAIT_MS=2000
INJECTED_TEXT_DISPATCH_EVENTS=true
INJECTED_TEXT_USE_NATIVE_SETTER=false
INJECTED_TEXT_FORCE_SYNTHETIC_SUBMIT=true
FILL_SPEED_TYPE_DELAY_MS=0
PASTE_FRAGMENTATION_CHUNKS=te,st,us,er1
PASTE_FRAGMENTATION_FORCE_SYNTHETIC_SUBMIT=true
KEY_INPUT_MISMATCH_VALUE=textuser
KEY_INPUT_MISMATCH_PASTE_VALUE=pasted
INTERACTION_SCORE_WAIT_MS=750
INTERACTION_SCORE_POLL_TIMEOUT_MS=5000
INTERACTION_SCORE_POLL_INTERVAL_MS=250
INTERACTION_SYNTHETIC_SUBMIT_COUNT=2
INTERACTION_SYNTHETIC_SUBMIT_GAP_MS=250

# Transient test retry controls. A failed test is retried only for page-readiness
# style failures such as null/undefined values, missing selectors, detached
# frames, destroyed execution contexts, or timeouts. Assertion mismatches still
# fail immediately.
TEST_RETRY_ATTEMPTS=3
TEST_RETRY_DELAY_MS=3000

# Validate normal-session dfs_E_1 is not reporting private/incognito mode.
PERFORM_PRIVATE_MODE_DETECTION_TEST=true

# Launch an additional browser in private/incognito mode where the runner has a
# supported launch strategy, then validate dfs_E_1.
PERFORM_PRIVATE_MODE_BROWSER_TEST=true


# Relax specific cookie expectations for known environment differences.
IGNORE_REQUIRED_DFS_COOKIES=


# =============================================================================
# Diagnostics and runner internals
# =============================================================================
BROWSER_CLOSE_TIMEOUT_MS=5000
BROWSER_DIAGNOSTICS_TIMEOUT_MS=5000
TRACE_STEPS=false
STEP_STALL_LOG_MS=0
STEP_TIMEOUT_MS=60000

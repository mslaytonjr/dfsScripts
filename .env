RELEASE_VERSION=121.0.0-alpha.2.1
SCRIPT_OVERRIDE_MATCH=/aegis-binaries\/dfs\.js/i
SCRIPT_OVERRIDE_SOURCE=C:\GitRepo\dfsScripts\.ignore\dfs.js

LOBS=PUBLIC,SECURE

PUBLIC.TARGET_URL=https://www.chase.com
PUBLIC.USERNAME_SELECTOR=#userId-text-input-field
PUBLIC.PASSWORD_SELECTOR=#password-text-input-field
PUBLIC.SUBMIT_SELECTOR=#signin-button

SECURE.TARGET_URL=https://secure.chase.com
SECURE.LOGIN_FRAME_NAME=logonbox
SECURE.LOGIN_BEFORE_MOUSE=true
SECURE.USERNAME_SELECTOR=#userId-input-field-input
SECURE.PASSWORD_SELECTOR=#password-input-field-input
SECURE.SUBMIT_SELECTOR=#signin-button

# Required only when TEST_LOGON=true.
LOGIN_USERNAME=TestUserMark
LOGIN_PASSWORD=badpass
TEST_LOGON=true
LOGIN_REQUEST_MATCHER=/auth|login|signin|signon/i

# Optional: comma-separated browser keys from browser-paths.properties.
# Leave blank to run every configured executable path.
BROWSERS=

HEADLESS=false
DISCOVER_INPUTS_ONLY=false
TRACE_STEPS=false
STEP_STALL_LOG_MS=0
PERFORM_MOUSE_MOVEMENT=true
FIREFOX_USE_PLAYWRIGHT_BUNDLED=true

# Playwright-launched browsers are expected to identify webdriver.
# Set to 0 only for a separate manual/non-webdriver validation run.
EXPECTED_DFS_E7_BIT0=1
DFS_E7_CLIENT_HINTS_MISSING_BROWSERS=opera,firefox

NAVIGATION_TIMEOUT_MS=5000
POST_LOAD_WAIT_MS=10000
LOGIN_REQUEST_TIMEOUT_MS=10000
MOUSE_WAIT_BEFORE_MS=15000
MOUSE_WAIT_AFTER_MS=1000
USERNAME_TYPE_DELAY_MS=100
PASSWORD_TYPE_DELAY_MS=100

# If dfs_E_8 should equal something different from RELEASE_VERSION, set it here.
EXPECTED_DFS_E_8=

IGNORE_DFS_E7_BIT16=false
IGNORE_REQUIRED_DFS_COOKIES=

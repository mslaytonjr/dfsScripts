# TARGET_URL=https://wwwqa3.chase.com/
# TARGET_URL=secure.chase.com
TARGET_URL=https://www.chase.com
RELEASE_VERSION=1.20.0-beta.11
# SCRIPT_OVERRIDE_MATCH=/aegis-binaries\/dfs\.js/i
# SCRIPT_OVERRIDE_SOURCE=C:\JSOverrides\static.chasecdn.com\web\library\pseaegis\aegis-binaries\dfs.js

# Optional: comma-separated browser keys from browser-paths.properties.
# Leave blank to run every configured executable path.
BROWSERS=

HEADLESS=false
PERFORM_MOUSE_MOVEMENT=true
SUBMIT_CREDENTIALS=false
FIREFOX_USE_PLAYWRIGHT_BUNDLED=true

# Playwright-launched browsers are expected to identify webdriver.
# Set to 0 only for a separate manual/non-webdriver validation run.
EXPECTED_DFS_E7_BIT0=1

# Required only when SUBMIT_CREDENTIALS=true.
LOGIN_USERNAME=TestUserMark
LOGIN_PASSWORD=badpass
USERNAME_SELECTOR=
PASSWORD_SELECTOR=
SUBMIT_SELECTOR=
LOGIN_REQUEST_MATCHER=

NAVIGATION_TIMEOUT_MS=5000
POST_LOAD_WAIT_MS=10000
FIELD_TIMEOUT_MS=5000
LOGIN_REQUEST_TIMEOUT_MS=10000
MOUSE_WAIT_BEFORE_MS=15000
MOUSE_WAIT_AFTER_MS=1000

# If dfs_E_8 should equal something different from RELEASE_VERSION, set it here.
EXPECTED_DFS_E_8=

IGNORE_DFS_E7_BIT16=true
IGNORE_REQUIRED_DFS_COOKIES=dfs_E_5
